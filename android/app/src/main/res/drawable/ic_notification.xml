<?xml version="1.0" encoding="utf-8"?>
<!--
    Notification small icon — must be white/transparent only.
    Android renders notification icons as white silhouettes on a colored background.
    Using a pure-white path here ensures correct rendering across all API levels and OEM themes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Shield outline — filled white, rendered as silhouette by the system -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M12,2 L20,6 L20,13 C20,17.4 16.5,21.4 12,23 C7.5,21.4 4,17.4 4,13 L4,6 Z" />
    <!-- Checkmark overlay (slightly transparent so the shield shape reads clearly) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#0A0C10"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M9,12.5 L11,14.5 L15,10.5" />
</vector>
