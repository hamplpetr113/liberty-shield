<?xml version="1.0" encoding="utf-8"?>
<!--
    Threat model: Manifest security layer.
    Risk: Overly permissive manifest increases attack surface.
    Mitigation: Only declare permissions actually required. Uses protectionLevel checks
    at runtime for sensitive ops. FLAG_SECURE set in MainActivity.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.libertyshield.android">

    <!-- ===== PERMISSIONS ===== -->

    <!-- Sensor monitoring — foreground service types -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />

    <!-- Boot persistence -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Network sync -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Sensor access (runtime permissions) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Package enumeration for AppOps monitoring -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Usage stats for background detection -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Battery + wake lock -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ===== QUERIES ===== -->
    <!-- Declare intent queries for package visibility on Android 11+ -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
        </intent>
    </queries>

    <!-- ===== APPLICATION ===== -->
    <application
        android:name=".LibertyShieldApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LibertyShield"
        tools:targetApi="31">

        <!-- ===== MAIN ACTIVITY ===== -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===== FOREGROUND SERVICE ===== -->
        <!--
            Threat model: Service isolation.
            exported=false prevents external apps from binding/starting this service.
            foregroundServiceType restricts what hardware this service can access.
        -->
        <service
            android:name=".service.SensorMonitorService"
            android:exported="false"
            android:foregroundServiceType="microphone|camera"
            android:stopWithTask="false" />

        <!-- ===== BOOT RECEIVER ===== -->
        <!--
            Threat model: Persistence via boot.
            exported=true is required for BOOT_COMPLETED to be delivered by the system.
            Risk mitigated: only our own service is started — no external data consumed.
        -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <!-- WorkManager initialization provider (provided by library) -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup" />
        </provider>

    </application>

</manifest>
