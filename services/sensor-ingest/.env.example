# Required — same value as SENSOR_API_KEY in Vercel
SENSOR_API_KEY=liberty-shield-2026

# Upstash Redis connection string (rediss://default:password@host.upstash.io:6380)
# Get from Upstash console → your database → "Redis CLI" connection string
REDIS_URL=rediss://default:YOURPASSWORD@YOURHOST.upstash.io:6380

# Optional — path for append-only audit log file
AUDIT_LOG_FILE=/tmp/audit.log

# Port (Railway sets $PORT automatically; this is the fallback)
SENSOR_INGEST_PORT=3001
